---
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const currentPath = Astro.url.pathname;
---

<button id="sidebar-toggle" aria-label="開啟選單">
	<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
		<line x1="3" y1="6" x2="21" y2="6" />
		<line x1="3" y1="12" x2="21" y2="12" />
		<line x1="3" y1="18" x2="21" y2="18" />
	</svg>
</button>

<div id="sidebar-backdrop"></div>

<nav id="sidebar">
	<div class="sidebar-header">
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<button id="sidebar-close" aria-label="關閉選單">✕</button>
	</div>

	<div class="section-label">文章</div>
	<ul>
		<li>
			<a href="/" class:list={[{ active: currentPath === '/' }]}>
				所有文章
			</a>
		</li>
	</ul>
	<ul>
		{posts.map((post) => (
			<li>
				<a
					href={`/blog/${post.id}/`}
					class:list={[{ active: currentPath === `/blog/${post.id}/` }]}
				>
					{post.data.title}
				</a>
			</li>
		))}
	</ul>

	<div class="divider"></div>

	<ul>
		<li>
			<a href="https://github.com/cherites0610" target="_blank">
				<svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
				</svg>
				GitHub
			</a>
		</li>
	</ul>
</nav>

<script>
	const toggle = document.getElementById('sidebar-toggle');
	const close = document.getElementById('sidebar-close');
	const backdrop = document.getElementById('sidebar-backdrop');
	const sidebar = document.getElementById('sidebar');

	function openSidebar() {
		sidebar?.classList.add('open');
		backdrop?.classList.add('show');
	}
	function closeSidebar() {
		sidebar?.classList.remove('open');
		backdrop?.classList.remove('show');
	}

	toggle?.addEventListener('click', openSidebar);
	close?.addEventListener('click', closeSidebar);
	backdrop?.addEventListener('click', closeSidebar);
</script>

<style>
	#sidebar-toggle {
		position: fixed;
		top: 1rem;
		left: 1rem;
		z-index: 200;
		background: var(--bg-surface);
		border: 1px solid rgba(var(--gray), 20%);
		color: rgb(var(--black));
		border-radius: 6px;
		padding: 6px 8px;
		cursor: pointer;
		display: flex;
		align-items: center;
	}
	#sidebar-toggle:hover {
		background: rgba(var(--gray-light), 60%);
	}

	#sidebar-backdrop {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.5);
		z-index: 300;
	}
	#sidebar-backdrop.show {
		display: block;
	}

	#sidebar {
		position: fixed;
		top: 0;
		left: -280px;
		width: 260px;
		height: 100vh;
		overflow-y: auto;
		background: var(--bg-surface);
		z-index: 400;
		transition: left 0.25s ease;
		padding: 1.5rem;
		box-sizing: border-box;
		box-shadow: 4px 0 20px rgba(0, 0, 0, 0.4);
	}
	#sidebar.open {
		left: 0;
	}

	.sidebar-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.5rem;
	}
	.site-title {
		font-weight: 700;
		color: rgb(var(--black));
		font-size: 0.95rem;
		text-decoration: none;
	}
	.site-title:hover {
		color: var(--accent);
	}

	#sidebar-close {
		background: none;
		border: none;
		color: rgb(var(--gray));
		cursor: pointer;
		font-size: 1rem;
		padding: 4px;
	}
	#sidebar-close:hover {
		color: rgb(var(--black));
	}

	.section-label {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--gray));
		margin-bottom: 0.5rem;
		padding: 0 0.75rem;
	}

	.divider {
		border-top: 1px solid rgba(var(--gray), 20%);
		margin: 1rem 0;
	}

	ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	ul a {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0.75rem;
		border-radius: 6px;
		text-decoration: none;
		color: rgb(var(--gray));
		font-size: 0.85rem;
		line-height: 1.4;
		transition: background 0.15s, color 0.15s;
	}
	ul a:hover,
	ul a.active {
		background: rgba(var(--gray-light), 40%);
		color: rgb(var(--black));
	}
	ul a.active {
		color: var(--accent);
	}
</style>
